# Anthropic API (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Priority ODATA API
PRIORITY_BASE_URL=YOUR_PRIORITY_HOST
PRIORITY_TABULA_INI=tabula.ini
PRIORITY_COMPANY=YOUR_COMPANY
PRIORITY_USER=your-priority-api-token
PRIORITY_PASSWORD=PAT

# Google Sheets
SHEET_ID=your-google-sheet-id
SHEET_TAB=הזמנות

# GWS CLI — project-local config (customer's Google account)
GOOGLE_WORKSPACE_CLI_CONFIG_DIR=.gws-config
# Store the credential-encryption key in .gws-config/.encryption_key (a file the
# Docker container can read) instead of the host OS keyring (which the
# container can't reach). MUST be set BEFORE running `gws auth login` so the
# key is written to the file in the first place.
GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file

# Scheduler
LOAD_TIME=14:00
MONITOR_INTERVAL=5
MONITOR_UNTIL=18:00
# Auto-schedule master switch. Y = scheduler waits for LOAD_TIME and auto-runs
# (production behavior). N = scheduler stays idle; only manual dashboard /
# CLI triggers run the agent. Use N during the trust-building phase; flip to
# Y when ready, then `docker compose restart agent` to reload .env.
AUTO_SCHEDULE=Y
